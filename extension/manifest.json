{
  "manifest_version": 3,
  "name": "Rescoop",
  "version": "1.0.0",
  "description": "Save URLs as you browse. Export them in bulk.",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_text": ""
  },
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "save-url": {
      "suggested_key": { "default": "Alt+Shift+S" },
      "description": "Save current tab URL"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
